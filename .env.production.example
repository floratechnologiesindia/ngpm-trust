# Used with: docker compose -f docker-compose.prod.yml --env-file .env.production up --build -d
#
# Public URLs (also baked into web image at build time via docker-compose.prod.yml):
#   Site: https://ngpmandsmpm.org
#   API:  https://api.ngpmandsmpm.org

JWT_SECRET=use_a_long_random_string_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=use_a_strong_password_here

# Comma-separated list of origins allowed to call the API (browser CORS).
# Default in compose matches ngpmandsmpm.org and www; override if you use other hostnames.
CORS_ORIGIN=https://ngpmandsmpm.org,https://www.ngpmandsmpm.org

# Optional: host ports if you publish containers directly (reverse proxy can use internal ports instead)
# WEB_PUBLISH_PORT=6660
# API_PUBLISH_PORT=6661
